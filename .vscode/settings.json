{
  "cSpell.language": "en-GB",
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit"
  },
  "editor.detectIndentation": false,
  "editor.insertSpaces": true,
  "editor.rulers": [80, 120],
  "editor.tabSize": 2,
  "files.readonlyInclude": {
    "AGENTS.md": true,
    "pnpm-lock.yaml": true
  },
  "files.watcherExclude": {
    "AGENTS.md": true,
    "pnpm-lock.yaml": true
  },
  "search.exclude": {
    "AGENTS.md": true,
    "pnpm-lock.yaml": true
  }
}
